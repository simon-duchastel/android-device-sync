.externalNativeBuild
.cxx/

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint/reports/

# Keystore files (DO NOT COMMIT YOUR RELEASE KEYSTORE)
*.jks
*.keystore

# Google Services (e.g. APIs or Firebase)
google-services.json

# Android Profiling
*.hprof

# Kotlin
.kotlin/
